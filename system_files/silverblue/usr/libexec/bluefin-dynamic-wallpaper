#!/bin/bash

# Script to set the appropriate wallpaper based on month and hemisphere
# This will be run at login and periodically to update the wallpaper

# Determine the current month (1-12)
MONTH=$(date +%m)
MONTH_NUM=${MONTH#0}  # Remove leading zero if present

# Default to Northern hemisphere
HEMISPHERE="north"

# Check if we're in the Southern hemisphere
# This uses the GeoClue service if available, otherwise falls back to IP-based geolocation
if command -v geoclue-where-am-i &> /dev/null; then
    # Use GeoClue if available
    LATITUDE=$(geoclue-where-am-i | grep -oP 'Latitude: \K[-0-9.]+')
    if [[ -n "$LATITUDE" && $(echo "$LATITUDE < 0" | bc) -eq 1 ]]; then
        HEMISPHERE="south"
    fi
else
    # Fallback to IP-based geolocation
    if command -v curl &> /dev/null; then
        GEOIP_DATA=$(curl -s https://ipapi.co/json/ 2>/dev/null)
        if [[ -n "$GEOIP_DATA" ]]; then
            LATITUDE=$(echo "$GEOIP_DATA" | grep -oP '"latitude":\s*\K[-0-9.]+')
            if [[ -n "$LATITUDE" && $(echo "$LATITUDE < 0" | bc) -eq 1 ]]; then
                HEMISPHERE="south"
            fi
        fi
    fi
fi

# For Southern hemisphere, adjust the month to get the opposite season
if [[ "$HEMISPHERE" == "south" ]]; then
    # Add 6 months and wrap around if needed
    MONTH_NUM=$(( (MONTH_NUM + 6 - 1) % 12 + 1 ))
fi

# Format month with leading zero if needed
if [[ $MONTH_NUM -lt 10 ]]; then
    MONTH_PADDED="0$MONTH_NUM"
else
    MONTH_PADDED="$MONTH_NUM"
fi

# Set the wallpaper
WALLPAPER_PATH="/usr/share/backgrounds/bluefin/${MONTH_PADDED}-bluefin.xml"

# Check if the wallpaper file exists
if [[ -f "$WALLPAPER_PATH" ]]; then
    # Set the wallpaper for the current user
    gsettings set org.gnome.desktop.background picture-uri "file://$WALLPAPER_PATH"
    gsettings set org.gnome.desktop.background picture-uri-dark "file://$WALLPAPER_PATH"
    
    # Log the change
    logger -t bluefin-dynamic-wallpaper "Set wallpaper to $WALLPAPER_PATH (Month: $MONTH_NUM, Hemisphere: $HEMISPHERE)"
else
    logger -t bluefin-dynamic-wallpaper "Wallpaper file not found: $WALLPAPER_PATH"
fi
